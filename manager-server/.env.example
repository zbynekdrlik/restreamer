# Manager Server - Environment Variables
# Copy this file to .env and fill in the values

# Django
SECRET_KEY=change-me-to-a-random-string

# Database (PostgreSQL)
DB_NAME=restreamer
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# S3 Object Storage (Linode)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Linode API (for provisioning delivering-service instances)
LINODE_TOKEN=
INSTANCE_TYPE_4G=g6-standard-2
INSTANCE_TYPE_1G=g6-nanode-1
INSTANCE_TYPE_8G=g6-standard-4
INSTANCE_REGION=eu-central
ROOT_SERVER_PASSWORD=

# Email (Gmail SMTP)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Cron security token
CRON_SECRET_TOKEN=
