{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "Restreamer",
  "version": "0.22.8",
  "identifier": "media.newlevel.restreamer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Restreamer Dashboard",
        "url": "http://127.0.0.1:8910",
        "width": 1024,
        "height": 768,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zbynekdrlik/restreamer/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMTI3M0YyQzg4OTRCOEQKUldTTlM0bkk4bk1TamJxT3lzbjNGL1hMQ25xbW9ieUJ0bG1Yck5IMG4vT09qSUM4RXp2Rzl2eE4K"
    }
  }
}
