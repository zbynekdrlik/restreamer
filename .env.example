# ============================================================
# Restreamer Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- local-client (Windows endpoint) ---
# S3 Object Storage (Linode)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Django
SECRET_KEY=change-me-to-a-random-string

# Manager server URL (where local-client reports to)
MANAGER_SERVER_URL=https://restreamer.newlevel.media

# --- delivering-service (Linux re-streamer) ---
# Uses the same AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY as above
# SENTRY_DSN=  (optional)

# --- manager-server (central management) ---
# Database (PostgreSQL)
DB_NAME=restreamer
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Email (Gmail SMTP)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Linode API
LINODE_TOKEN=
INSTANCE_TYPE_4G=g6-standard-2
INSTANCE_TYPE_1G=g6-nanode-1
INSTANCE_TYPE_8G=g6-standard-4
INSTANCE_REGION=eu-central
ROOT_SERVER_PASSWORD=

# Security
CRON_SECRET_TOKEN=
