# Restreamer Local Client - Environment Variables
# Copy this file to .env and fill in the values

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True

# S3 Object Storage (Linode) - REQUIRED
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=linode52
AWS_S3_REGION_NAME=eu-central-1
OBJECT_STORAGE_URL=https://eu-central-1.linodeobjects.com

# Linode API (optional, for provisioning)
LINODE_TOKEN=

# Manager server URL
MANAGER_SERVER_URL=https://restreamer.newlevel.media

# Redis (Celery broker)
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379
